<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.malayalampanchangam.calendar</string>
    </array>
    <!-- Temporary exception: grants read access to the group container path
         on dev-signed builds where App Group provisioning is unavailable. -->
    <key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
    <array>
        <string>/Library/Group Containers/group.com.malayalampanchangam.calendar/</string>
    </array>
</dict>
</plist>
